{}
[(Claim RoleClaim)
 (Release RoleRelease)
 (Handoff RoleHandoff)
 (Observe Observation)
 (Submit ActivitySubmission)
 (Query ActivityQuery)
 (RunWorkflow WorkflowRunRequest)
 (RunResolvedWorkflow ResolvedWorkflowRunRequest)
 (ObserveWorkflowRun WorkflowRunObservation opens WorkflowRunStream)
 (WorkflowRunObservationRetraction WorkflowRunObservationToken)
 (Watch ObservationSubscription opens ObservationStream)
 (Unwatch ObservationToken)
 (RegisterAgent OrchestratorAgentRegistration)]
[(ClaimAcceptance ClaimAcceptance)
 (ClaimRejection ClaimRejection)
 (ReleaseAcknowledgment ReleaseAcknowledgment)
 (HandoffAcceptance HandoffAcceptance)
 (HandoffRejection HandoffRejection)
 (RoleSnapshot RoleSnapshot)
 (SessionsObserved SessionsObserved)
 (LanesObserved LanesObserved)
 (WorktreesObserved WorktreesObserved)
 (ActivityAcknowledgment ActivityAcknowledgment)
 (ActivityList ActivityList)
 (WorkflowRunAccepted WorkflowRunAccepted)
 (WorkflowResolutionAccepted WorkflowRunResolution)
 (WorkflowResolutionUnavailable WorkflowResolutionUnavailable)
 (WorkflowReceiptProduced WorkflowReceiptProduced)
 (WorkflowResolvedReceiptProduced WorkflowResolvedReceiptProduced)
 (WorkflowRunLogReported WorkflowRunLogReported)
 (WorkflowRunObservationOpened WorkflowRunObservationOpened)
 (WorkflowRunObservationClosed WorkflowRunObservationClosed)
 (PartialApplied PartialApplied)
 (ObservationOpened ObservationOpened)
 (ObservationClosed ObservationClosed)
 (AgentRegistered AgentRegistered)
 (AgentRegistrationRejected AgentRegistrationRejected)
 (TopicTree TopicTree)
 (TopicDetail TopicDetail)
 (AgentDirectory AgentDirectory)]
{
  RoleIdentifier String
  RoleName RoleIdentifier
  RoleToken String
  RoleTokens (Vector RoleToken)
  Role RoleTokens
  SessionIdentifier String
  SessionName SessionIdentifier
  LaneAuthority [Structural Support]
  LaneIdentifier String
  LaneDetails String
  LaneStatus [Active Released HandoverEnded]
  LaneOwner { Role authority.LaneAuthority }
  LaneAssignment { session.SessionIdentifier lane.LaneIdentifier owner.LaneOwner details.LaneDetails }
  LaneRegistration { assignment.LaneAssignment registered_at.TimestampNanos status.LaneStatus }
  HarnessKind [Codex Claude]
  HarnessName String
  NamedModel String
  CapabilityProfile String
  ModelSelector [(Exact NamedModel) (CapabilityProfile CapabilityProfile)]
  EffortRequest [Minimal Low Medium High ExtraHigh Maximum]
  ModelRequest { selector.ModelSelector effort.EffortRequest }
  ClaudeSessionIdentifier String
  CodexContinuationIdentifier String
  PiContinuationIdentifier String
  ContinuationHandle [(Claude ClaudeSessionIdentifier) (Codex CodexContinuationIdentifier) (Pi PiContinuationIdentifier)]
  ContinuationRequest [Fresh (Prefer ContinuationHandle) (Require ContinuationHandle)]
  ModelResolutionRequest { model.ModelRequest continuation.ContinuationRequest }
  ResolvedHarnessKind [Codex Claude Pi Fixture]
  ModelResolved { harness.HarnessName harness_kind.ResolvedHarnessKind model.NamedModel effort.EffortRequest continuation.ContinuationHandle }
  ModelUnavailableReason [NoConfiguredHarness ModelNotKnown EffortUnsupported CapabilityUnsupported ProviderUnavailable ContinuationUnavailable AdapterConfigurationMissing]
  ModelUnavailable { request.ModelResolutionRequest reason.ModelUnavailableReason }
  WirePath String
  TaskToken String
  ScopeReason String
  ScopeReference [(Path WirePath) (Task TaskToken)]
  TimestampNanos Integer
  DurationNanos Integer
  WorkflowRunDigest String
  WorkflowStepName String
  ProviderName String
  ModelName String
  HostName String

  ;; Mirrors imported signal-criome nouns used by src/lib.rs. The source of
  ;; truth for these types remains signal-criome; they are repeated here only
  ;; so the generated schema mirror exposes the public shape.
  ObjectDigest String
  ContractDigest ObjectDigest
  OperationDigest ObjectDigest
  WorkflowDigest ObjectDigest
  WorkflowProvenanceDigest ObjectDigest
  AuthorizedObjectKind [Operation Contract Agreement Time Head]
  ComponentKind [Spirit Criome Router Mirror Lojix Persona Agent]
  AuthorizedObjectReference { component.ComponentKind digest.ObjectDigest kind.AuthorizedObjectKind }
  EvaluationRejectionReason [OutsideTimeWindow TimeNotProven AgreementMissing]
  EscalationTarget [Psyche (Workflow WorkflowDigest)]
  EvaluationDecision [Authorized Deferred NonJudgement (Escalate EscalationTarget) (Rejected EvaluationRejectionReason)]
  WorkflowReceipt { workflow.WorkflowDigest operation.OperationDigest outcome.EvaluationDecision provenance.WorkflowProvenanceDigest }

  RepositoryName String
  BranchName String
  LaneName String
  PurposeText String
  WorktreeStatus [Active Merged Archived Recycled]
  PushedState [Unpushed Pushed AncestorOfMain]
  Worktree { repository.RepositoryName branch.BranchName path.WirePath owning_lane.LaneName status.WorktreeStatus purpose.PurposeText last_activity.TimestampNanos PushedState }

  OrchestratorAgentIdentifier String
  OrchestratorTopicPath String
  TopicName String
  MissionDescription String
  OrchestratorTopicPaths (Vector OrchestratorTopicPath)
  OrchestratorTopic { path.OrchestratorTopicPath name.TopicName parent.(Optional OrchestratorTopicPath) }
  OrchestratorTopics (Vector OrchestratorTopic)
  OrchestratorAgentStatus [Active Retired]
  OrchestratorAgentSummary { agent_identifier.OrchestratorAgentIdentifier mission.MissionDescription topics.OrchestratorTopicPaths status.OrchestratorAgentStatus }
  OrchestratorAgentSummaries (Vector OrchestratorAgentSummary)
  OrchestratorAgentIdentifiers (Vector OrchestratorAgentIdentifier)
  TopicAssignmentSource [Judge Explicit]
  TopicSelection [Automatic (Explicit OrchestratorTopicPaths)]
  OrchestratorAgentRegistration { session.SessionIdentifier mission.MissionDescription harness.HarnessKind TopicSelection }
  AgentRegistered { agent_identifier.OrchestratorAgentIdentifier assigned_topics.OrchestratorTopics assignment_source.TopicAssignmentSource }
  AgentRegistrationRejectionReason [MissionEmpty MissionTooVague UnknownTopic JudgeUnavailable JudgeMalformed JudgeTimedOut]
  AgentRegistrationRejected { reason.AgentRegistrationRejectionReason available_topics.OrchestratorTopics }
  TopicTree { topics.OrchestratorTopics }
  TopicDetail { topic.OrchestratorTopic member_agent_identifiers.OrchestratorAgentIdentifiers }
  AgentDirectory { agents.OrchestratorAgentSummaries }

  ScopeReferences (Vector ScopeReference)
  ActivityFilters (Vector ActivityFilter)
  ScopeConflicts (Vector ScopeConflict)
  LaneRegistrations (Vector LaneRegistration)
  SessionProjections (Vector SessionProjection)
  LaneProjections (Vector LaneProjection)
  LaneResourceClaims (Vector LaneResourceClaim)
  Worktrees (Vector Worktree)
  RoleStatuses (Vector RoleStatus)
  Activities (Vector Activity)
  ClaimEntries (Vector ClaimEntry)
  ApplicationSuccesses (Vector ApplicationSuccess)
  ApplicationFailures (Vector ApplicationFailure)

  RoleClaim { role.RoleName scopes.ScopeReferences reason.ScopeReason }
  RoleRelease RoleName
  RoleHandoff { from.RoleName to.RoleName scopes.ScopeReferences reason.ScopeReason }
  Observation [Roles Sessions (SessionLanes SessionIdentifier) Lanes Worktrees Topics (Topic OrchestratorTopicPath) Agents]
  ActivitySubmission { role.RoleName scope.ScopeReference reason.ScopeReason }
  ActivityQuery { limit.Integer filters.ActivityFilters }
  ActivityFilter [(RoleFilter RoleName) (PathPrefix WirePath) (TaskToken TaskToken)]
  ObservationSubscription { include_operations.Boolean include_effects.Boolean }
  ObservationToken Integer

  ClaimAcceptance { role.RoleName scopes.ScopeReferences }
  ClaimRejection { role.RoleName conflicts.ScopeConflicts }
  ScopeConflict { scope.ScopeReference held_by.RoleName held_reason.ScopeReason }
  ReleaseAcknowledgment { role.RoleName released_scopes.ScopeReferences }
  HandoffAcceptance { from.RoleName to.RoleName scopes.ScopeReferences }
  HandoffRejection { from.RoleName to.RoleName reason.HandoffRejectionReason }
  HandoffRejectionReason [SourceRoleDoesNotHold (TargetRoleConflict ScopeConflicts)]
  RoleSnapshot { roles.RoleStatuses recent_activity.Activities }
  SessionsObserved { sessions.SessionProjections }
  LanesObserved { lanes.LaneProjections }
  SessionProjection { session.SessionIdentifier active_lanes.Integer }
  LaneProjection { registration.LaneRegistration resource_claims.LaneResourceClaims observed_at.TimestampNanos age.DurationNanos }
  LaneResourceClaim { scope.ScopeReference reason.ScopeReason claimed_at.TimestampNanos age.DurationNanos }
  WorktreesObserved { Worktrees }
  RoleStatus { role.RoleName harness.HarnessKind claims.ClaimEntries }
  ClaimEntry { scope.ScopeReference reason.ScopeReason claimed_at.TimestampNanos age.DurationNanos }
  Activity { role.RoleName scope.ScopeReference reason.ScopeReason stamped_at.TimestampNanos }
  ActivityAcknowledgment Integer
  ActivityList Activities

  WorkflowRunRequest { workflow.WorkflowDigest operation.AuthorizedObjectReference contract.ContractDigest }
  ResolvedWorkflowRunRequest { workflow_run.WorkflowRunRequest model_resolution.ModelResolutionRequest }
  WorkflowRunObservation { run.WorkflowRunDigest }
  WorkflowRunObservationToken { run.WorkflowRunDigest }
  WorkflowRunHandle { run.WorkflowRunDigest }
  WorkflowRunAccepted { handle.WorkflowRunHandle }
  WorkflowRunResolution { handle.WorkflowRunHandle resolution.ModelResolved }
  WorkflowResolutionUnavailable { handle.WorkflowRunHandle request.ResolvedWorkflowRunRequest unavailable.ModelUnavailable }
  WorkflowReceiptProduced { handle.WorkflowRunHandle receipt.WorkflowReceipt }
  WorkflowResolvedReceiptProduced { run.WorkflowRunResolution receipt.WorkflowReceipt }
  WorkflowRunLogReported { log.WorkflowRunLog }
  WorkflowRunLog { run.WorkflowRunDigest step_logs.(Vector StepLog) }
  StepLog { step.WorkflowStepName attestation.ModelAttestation outcome.StepOutcome }
  ModelAttestation { provider.ProviderName model.ModelName host.HostName call.OperationDigest }
  StepOutcome [(Produced EvaluationDecision) (Failed ScopeReason)]
  WorkflowDefinition { steps.(Vector WorkflowStep) combination.CombinationRule escalation.(Optional EscalationTarget) }
  WorkflowStep { name.WorkflowStepName prompt.ObjectDigest provider.(Optional ProviderName) dependencies.(Vector WorkflowStepName) }
  CombinationRule [(Threshold StepThreshold) Unanimous AnyApprove]
  StepThreshold Integer
  WorkflowRunSnapshot { handle.WorkflowRunHandle latest_log.(Optional WorkflowRunLog) receipt.(Optional WorkflowReceipt) }
  WorkflowRunObservationOpened { token.WorkflowRunObservationToken snapshot.WorkflowRunSnapshot }
  WorkflowRunObservationClosed { token.WorkflowRunObservationToken }
  WorkflowRunUpdate { run.WorkflowRunDigest log.(Optional WorkflowRunLog) receipt.(Optional WorkflowReceipt) }

  DownstreamComponent [Router Harness Terminal Message Mind System Introspect]
  ApplicationFailureReason [Unreachable Rejected Unimplemented TimedOut Unknown]
  ApplicationSuccess { component.DownstreamComponent detail.ScopeReason }
  ApplicationFailure { component.DownstreamComponent reason.ApplicationFailureReason detail.ScopeReason }
  PartialApplied { succeeded.ApplicationSuccesses failed.ApplicationFailures }

  ObservationOpened ObservationToken
  ObservationClosed ObservationToken
  OperationKind [Claim Release Handoff Observe Submit Query RunWorkflow RunResolvedWorkflow ObserveWorkflowRun WorkflowRunObservationRetraction Watch Unwatch RegisterAgent]
  EffectOutcome [Applied Removed Changed Observed StreamOpened StreamClosed NoChange]
  OperationReceived OperationKind
  EffectEmitted { operation.OperationKind outcome.EffectOutcome }
  WorkflowRunEvent [(WorkflowRunUpdated WorkflowRunUpdate belongs WorkflowRunStream)]
  ObservationEvent [(OperationReceived OperationReceived belongs ObservationStream)
                    (EffectEmitted EffectEmitted belongs ObservationStream)]
  WorkflowRunStream (Stream { token.WorkflowRunObservationToken opened.WorkflowRunObservationOpened event.WorkflowRunEvent close.WorkflowRunObservationToken })
  ObservationStream (Stream { token.ObservationToken opened.ObservationOpened event.ObservationEvent close.ObservationToken })
}

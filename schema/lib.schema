{}
[(Claim RoleClaim)
 (Release RoleRelease)
 (Handoff RoleHandoff)
 (Observe Observation)
 (Submit ActivitySubmission)
 (Query ActivityQuery)
 (RunWorkflow WorkflowRunRequest)
 (RunResolvedWorkflow ResolvedWorkflowRunRequest)
 (ObserveWorkflowRun WorkflowRunObservation opens WorkflowRunStream)
 (WorkflowRunObservationRetraction WorkflowRunObservationToken)
 (Watch ObservationSubscription opens ObservationStream)
 (Unwatch ObservationToken)
 (RegisterAgent OrchestratorAgentRegistration)
 (RequestWorktree WorktreeRequest)
 (ConcludeWorktree WorktreeConclusionRequest)
 (MintAgentIdentity AgentIdentityMintRequest)
 (LaunchAgent AgentLaunchRequest)]
[(ClaimAcceptance ClaimAcceptance)
 (ClaimRejection ClaimRejection)
 (ReleaseAcknowledgment ReleaseAcknowledgment)
 (HandoffAcceptance HandoffAcceptance)
 (HandoffRejection HandoffRejection)
 (RoleSnapshot RoleSnapshot)
 (SessionsObserved SessionsObserved)
 (LanesObserved LanesObserved)
 (WorktreesObserved WorktreesObserved)
 (RepositoriesObserved RepositoriesObserved)
 (ActivityAcknowledgment ActivityAcknowledgment)
 (ActivityList ActivityList)
 (WorkflowRunAccepted WorkflowRunAccepted)
 (WorkflowResolutionAccepted WorkflowRunResolution)
 (WorkflowResolutionUnavailable WorkflowResolutionUnavailable)
 (WorkflowReceiptProduced WorkflowReceiptProduced)
 (WorkflowResolvedReceiptProduced WorkflowResolvedReceiptProduced)
 (WorkflowRunLogReported WorkflowRunLogReported)
 (WorkflowRunObservationOpened WorkflowRunObservationOpened)
 (WorkflowRunObservationClosed WorkflowRunObservationClosed)
 (PartialApplied PartialApplied)
 (ObservationOpened ObservationOpened)
 (ObservationClosed ObservationClosed)
 (AgentRegistered AgentRegistered)
 (AgentRegistrationRejected AgentRegistrationRejected)
 (TopicTree TopicTree)
 (TopicDetail TopicDetail)
 (AgentDirectory AgentDirectory)
 (WorktreeScaffolded WorktreeScaffolded)
 (WorktreeRequestRejected WorktreeRequestRejected)
 (WorktreeConcluded WorktreeConcluded)
 (WorktreeTeardownRefused WorktreeTeardownRefused)
 (AgentIdentityMinted AgentIdentityMinted)
 (AgentLaunched AgentLaunched)
 (AgentLaunchRefused AgentLaunchRefused)
 (RepositoryMainContended RepositoryMainContended)]
{
  RoleIdentifier String
  RoleName RoleIdentifier
  RoleToken String
  RoleTokens (Vector RoleToken)
  Role RoleTokens
  SessionIdentifier String
  SessionName SessionIdentifier
  LaneAuthority [Structural Support]
  LaneIdentifier String
  LaneDetails String
  LaneStatus [Active Released HandoverEnded Suspect]
  LaneOwner { Role LaneAuthority }
  LaneAssignment { SessionIdentifier LaneIdentifier LaneOwner LaneDetails }
  LaneRegistration { LaneAssignment TimestampNanos LaneStatus }
  HarnessKind [Codex Claude]
  HarnessName String
  NamedModel String
  CapabilityProfile String
  ModelSelector [(Exact NamedModel) (CapabilityProfile CapabilityProfile)]
  EffortRequest [Minimal Low Medium High ExtraHigh Maximum]
  ModelRequest { ModelSelector EffortRequest }
  ClaudeSessionIdentifier String
  CodexContinuationIdentifier String
  PiContinuationIdentifier String
  ContinuationHandle [(Claude ClaudeSessionIdentifier) (Codex CodexContinuationIdentifier) (Pi PiContinuationIdentifier)]
  ContinuationRequest [Fresh (Prefer ContinuationHandle) (Require ContinuationHandle)]
  ModelResolutionRequest { ModelRequest ContinuationRequest }
  ResolvedHarnessKind [Codex Claude Pi Fixture]
  ModelResolved { HarnessName ResolvedHarnessKind NamedModel EffortRequest ContinuationHandle }
  ModelUnavailableReason [NoConfiguredHarness ModelNotKnown EffortUnsupported CapabilityUnsupported ProviderUnavailable ContinuationUnavailable AdapterConfigurationMissing]
  ModelUnavailable { ModelResolutionRequest ModelUnavailableReason }
  WirePath String
  TaskToken String
  ScopeReason String
  ScopeReference [(Path WirePath) (Task TaskToken)]
  TimestampNanos Integer
  DurationNanos Integer
  WorkflowRunDigest String
  WorkflowStepName String
  ProviderName String
  ModelName String
  HostName String

  ;; Mirrors imported signal-criome nouns used by src/lib.rs. The source of
  ;; truth for these types remains signal-criome; they are repeated here only
  ;; so the generated schema mirror exposes the public shape.
  ObjectDigest String
  ContractDigest ObjectDigest
  OperationDigest ObjectDigest
  WorkflowDigest ObjectDigest
  WorkflowProvenanceDigest ObjectDigest
  AuthorizedObjectKind [Operation Contract Agreement Time Head]
  ComponentKind [Spirit Criome Router Mirror Lojix Persona Agent]
  AuthorizedObjectReference { ComponentKind ObjectDigest AuthorizedObjectKind }
  EvaluationRejectionReason [OutsideTimeWindow TimeNotProven AgreementMissing]
  EscalationTarget [Psyche (Workflow WorkflowDigest)]
  EvaluationDecision [Authorized Deferred NonJudgement (Escalate EscalationTarget) (Rejected EvaluationRejectionReason)]
  WorkflowReceipt { WorkflowDigest OperationDigest EvaluationDecision WorkflowProvenanceDigest }

  RepositoryName String
  RepositoryHost String
  RepositoryOwner String
  RepositoryIdentity { RepositoryHost RepositoryOwner RepositoryName }
  RepositoryIdentityGap String
  RepositoryIdentityState [(Identified RepositoryIdentity) (IdentityUnknown RepositoryIdentityGap)]
  Repository { RepositoryIdentityState RepositoryName WirePath Boolean TimestampNanos }
  BranchName String
  LaneName String
  PurposeText String
  WorktreeStatus [Active Merged Archived Recycled Abandoned]
  PushedState [Unpushed Pushed AncestorOfMain]
  Worktree { RepositoryName BranchName WirePath LaneName WorktreeStatus PurposeText TimestampNanos PushedState }
  WorktreeConclusion [Merged Rejected]
  WorktreeRequest { RepositoryName BranchName LaneName PurposeText }
  WorktreeConclusionRequest { LaneName WorktreeConclusion }
  WorktreeRequestRejection [RepositoryNotFound WorktreeAlreadyExists (RepositoryAbsentLocally RepositoryIdentity)]
  WorktreeScaffolded { Worktree }
  WorktreeRequestRejected { WorktreeRequestRejection }
  MainIntegration [AlreadyAncestor FastForwarded Rebased Discarded]
  WorktreeConcluded { Worktree MainIntegration }
  TeardownRefusal [UnmergedWorkPresent AutoRebaseConflicted MainPushRejected]
  WorktreeTeardownRefused { Worktree TeardownRefusal }
  FeatureWorktree [(Scaffolded Worktree) (Existing Worktree)]
  RepositoryMainContended { RepositoryName RoleName ScopeReason DurationNanos FeatureWorktree }

  OrchestratorAgentIdentifier String
  OrchestratorTopicPath String
  TopicName String
  MissionDescription String
  OrchestratorTopicPaths (Vector OrchestratorTopicPath)
  OrchestratorTopic { OrchestratorTopicPath TopicName (Optional OrchestratorTopicPath) }
  OrchestratorTopics (Vector OrchestratorTopic)
  OrchestratorAgentStatus [Active Retired Dead Allocated]
  OrchestratorAgentSummary { OrchestratorAgentIdentifier MissionDescription OrchestratorTopicPaths OrchestratorAgentStatus }
  OrchestratorAgentSummaries (Vector OrchestratorAgentSummary)
  OrchestratorAgentIdentifiers (Vector OrchestratorAgentIdentifier)
  TopicAssignmentSource [Judge Explicit]
  TopicSelection [Automatic (Explicit OrchestratorTopicPaths)]
  MintedIdentitySelection [None (PreMinted OrchestratorAgentIdentifier)]
  OrchestratorAgentRegistration { SessionIdentifier MissionDescription HarnessKind TopicSelection MintedIdentitySelection }
  AgentRegistered { OrchestratorAgentIdentifier OrchestratorTopics TopicAssignmentSource }
  AgentIdentityMintRequest { SessionIdentifier MissionDescription HarnessKind }
  AgentIdentityMinted { OrchestratorAgentIdentifier }
  AgentLaunchRequest { OrchestratorAgentIdentifier }
  AgentLaunched { OrchestratorAgentIdentifier Integer (Optional WirePath) }
  AgentLaunchRefusalReason [UnknownAgent AgentNotAllocated HarnessUnreachable HarnessRefused]
  AgentLaunchRefused { OrchestratorAgentIdentifier AgentLaunchRefusalReason String }
  AgentRegistrationRejectionReason [MissionEmpty MissionTooVague UnknownTopic JudgeUnavailable JudgeMalformed JudgeTimedOut]
  AgentRegistrationRejected { AgentRegistrationRejectionReason OrchestratorTopics }
  TopicTree { OrchestratorTopics }
  TopicDetail { OrchestratorTopic OrchestratorAgentIdentifiers }
  AgentDirectory { OrchestratorAgentSummaries }

  ScopeReferences (Vector ScopeReference)
  ActivityFilters (Vector ActivityFilter)
  ScopeConflicts (Vector ScopeConflict)
  LaneRegistrations (Vector LaneRegistration)
  SessionProjections (Vector SessionProjection)
  LaneProjections (Vector LaneProjection)
  LaneResourceClaims (Vector LaneResourceClaim)
  Worktrees (Vector Worktree)
  Repositories (Vector Repository)
  RoleStatuses (Vector RoleStatus)
  Activities (Vector Activity)
  ClaimEntries (Vector ClaimEntry)
  ApplicationSuccesses (Vector ApplicationSuccess)
  ApplicationFailures (Vector ApplicationFailure)

  RoleClaim { RoleName ScopeReferences ScopeReason }
  RoleRelease RoleName
  RoleHandoff { from.RoleName to.RoleName ScopeReferences ScopeReason }
  Observation [Roles Sessions (SessionLanes SessionIdentifier) Lanes Worktrees Repositories Topics (Topic OrchestratorTopicPath) Agents]
  ActivitySubmission { RoleName ScopeReference ScopeReason }
  ActivityQuery { Integer ActivityFilters }
  ActivityFilter [(RoleFilter RoleName) (PathPrefix WirePath) (TaskToken TaskToken)]
  ObservationSubscription { include_operations.Boolean include_effects.Boolean }
  ObservationToken Integer

  ClaimAcceptance { RoleName ScopeReferences }
  ClaimRejection { RoleName ScopeConflicts }
  ScopeConflict { ScopeReference RoleName ScopeReason }
  ReleaseAcknowledgment { RoleName ScopeReferences Worktrees }
  HandoffAcceptance { from.RoleName to.RoleName ScopeReferences }
  HandoffRejection { from.RoleName to.RoleName HandoffRejectionReason }
  HandoffRejectionReason [SourceRoleDoesNotHold (TargetRoleConflict ScopeConflicts)]
  RoleSnapshot { RoleStatuses Activities }
  SessionsObserved { SessionProjections }
  LanesObserved { LaneProjections }
  SessionProjection { SessionIdentifier Integer }
  LaneProjection { LaneRegistration LaneResourceClaims TimestampNanos DurationNanos }
  LaneResourceClaim { ScopeReference ScopeReason TimestampNanos DurationNanos }
  WorktreesObserved { Worktrees }
  RepositoriesObserved { Repositories }
  RoleStatus { RoleName HarnessKind ClaimEntries }
  ClaimEntry { ScopeReference ScopeReason TimestampNanos DurationNanos }
  Activity { RoleName ScopeReference ScopeReason TimestampNanos }
  ActivityAcknowledgment Integer
  ActivityList Activities

  WorkflowRunRequest { WorkflowDigest AuthorizedObjectReference ContractDigest }
  ResolvedWorkflowRunRequest { WorkflowRunRequest ModelResolutionRequest }
  WorkflowRunObservation { WorkflowRunDigest }
  WorkflowRunObservationToken { WorkflowRunDigest }
  WorkflowRunHandle { WorkflowRunDigest }
  WorkflowRunAccepted { WorkflowRunHandle }
  WorkflowRunResolution { WorkflowRunHandle ModelResolved }
  WorkflowResolutionUnavailable { WorkflowRunHandle ResolvedWorkflowRunRequest ModelUnavailable }
  WorkflowReceiptProduced { WorkflowRunHandle WorkflowReceipt }
  WorkflowResolvedReceiptProduced { WorkflowRunResolution WorkflowReceipt }
  WorkflowRunLogReported { WorkflowRunLog }
  WorkflowRunLog { WorkflowRunDigest (Vector StepLog) }
  StepLog { WorkflowStepName ModelAttestation StepOutcome }
  ModelAttestation { ProviderName ModelName HostName OperationDigest }
  StepOutcome [(Produced EvaluationDecision) (Failed ScopeReason)]
  WorkflowDefinition { (Vector WorkflowStep) CombinationRule (Optional EscalationTarget) }
  WorkflowStep { WorkflowStepName ObjectDigest (Optional ProviderName) (Vector WorkflowStepName) }
  CombinationRule [(Threshold StepThreshold) Unanimous AnyApprove]
  StepThreshold Integer
  WorkflowRunSnapshot { WorkflowRunHandle (Optional WorkflowRunLog) (Optional WorkflowReceipt) }
  WorkflowRunObservationOpened { WorkflowRunObservationToken WorkflowRunSnapshot }
  WorkflowRunObservationClosed { WorkflowRunObservationToken }
  WorkflowRunUpdate { WorkflowRunDigest (Optional WorkflowRunLog) (Optional WorkflowReceipt) }

  DownstreamComponent [Router Harness Terminal Message Mind System Introspect]
  ApplicationFailureReason [Unreachable Rejected Unimplemented TimedOut Unknown]
  ApplicationSuccess { DownstreamComponent ScopeReason }
  ApplicationFailure { DownstreamComponent ApplicationFailureReason ScopeReason }
  PartialApplied { ApplicationSuccesses ApplicationFailures }

  ObservationOpened ObservationToken
  ObservationClosed ObservationToken
  OperationKind [Claim Release Handoff Observe Submit Query RunWorkflow RunResolvedWorkflow ObserveWorkflowRun WorkflowRunObservationRetraction Watch Unwatch RegisterAgent RequestWorktree ConcludeWorktree MintAgentIdentity LaunchAgent]
  EffectOutcome [Applied Removed Changed Observed StreamOpened StreamClosed NoChange]
  OperationReceived OperationKind
  EffectEmitted { OperationKind EffectOutcome }
  WorkflowRunEvent [(WorkflowRunUpdated WorkflowRunUpdate belongs WorkflowRunStream)]
  ObservationEvent [(OperationReceived OperationReceived belongs ObservationStream)
                    (EffectEmitted EffectEmitted belongs ObservationStream)]
  WorkflowRunStream (Stream { token.WorkflowRunObservationToken opened.WorkflowRunObservationOpened event.WorkflowRunEvent close.WorkflowRunObservationToken })
  ObservationStream (Stream { token.ObservationToken opened.ObservationOpened event.ObservationEvent close.ObservationToken })
}

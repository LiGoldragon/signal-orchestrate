[]

[]

{
  Claim [(RoleClaim RoleClaim)]
  Release [(RoleRelease RoleRelease)]
  Handoff [(RoleHandoff RoleHandoff)]
  Observe [(Observation Observation)]
  Submit [(ActivitySubmission ActivitySubmission)]
  Query [(ActivityQuery ActivityQuery)]
  RunWorkflow [(WorkflowRunRequest WorkflowRunRequest)]
  ObserveWorkflowRun [(WorkflowRunObservation WorkflowRunObservation)]
  WorkflowRunObservationRetraction [(WorkflowRunObservationToken WorkflowRunObservationToken)]
  Watch [(ObservationSubscription ObservationSubscription)]
  Unwatch [(ObservationToken ObservationToken)]

  RoleIdentifier (String)
  RoleName (RoleIdentifier)
  RoleToken (String)
  Role ((Vec RoleToken))
  LaneAuthority [Structural Support]
  LaneIdentifier (String)
  LaneRegistration (LaneIdentifier Role LaneAuthority)
  HarnessKind [Codex Claude]
  WirePath (String)
  TaskToken (String)
  ScopeReason (String)
  ScopeReference [(Path WirePath) (Task TaskToken)]
  TimestampNanos (u64)
  WorkflowRunDigest (String)
  WorkflowStepName (String)
  ProviderName (String)
  ModelName (String)
  HostName (String)
  ObjectDigest (String)
  ContractDigest (ObjectDigest)
  OperationDigest (ObjectDigest)
  WorkflowDigest (ObjectDigest)
  WorkflowProvenanceDigest (ObjectDigest)
  AuthorizedObjectKind [Operation Contract Agreement Time Head]
  ComponentKind [Spirit Criome Router Mirror Lojix Persona Agent]
  AuthorizedObjectReference (ComponentKind ObjectDigest AuthorizedObjectKind)
  EvaluationRejectionReason [OutsideTimeWindow TimeNotProven AgreementMissing]
  EscalationTarget [Psyche (Workflow WorkflowDigest)]
  EvaluationDecision [Authorized Deferred NonJudgement (Escalate EscalationTarget) (Rejected EvaluationRejectionReason)]
  WorkflowReceipt (WorkflowDigest OperationDigest EvaluationDecision WorkflowProvenanceDigest)

  RoleClaim (RoleName (Vec ScopeReference) ScopeReason)
  RoleRelease (RoleName)
  RoleHandoff (RoleName RoleName (Vec ScopeReference) ScopeReason)
  Observation [Roles Lanes]
  ActivitySubmission (RoleName ScopeReference ScopeReason)
  ActivityQuery (u32 (Vec ActivityFilter))
  ActivityFilter [(RoleFilter RoleName) (PathPrefix WirePath) (TaskToken TaskToken)]
  ObservationSubscription (Boolean Boolean)
  ObservationToken (u64)

  ClaimAcceptance (RoleName (Vec ScopeReference))
  ClaimRejection (RoleName (Vec ScopeConflict))
  ScopeConflict (ScopeReference RoleName ScopeReason)
  ReleaseAcknowledgment (RoleName (Vec ScopeReference))
  HandoffAcceptance (RoleName RoleName (Vec ScopeReference))
  HandoffRejection (RoleName RoleName HandoffRejectionReason)
  HandoffRejectionReason [SourceRoleDoesNotHold (TargetRoleConflict (Vec ScopeConflict))]
  RoleSnapshot ((Vec RoleStatus) (Vec Activity))
  LanesObserved ((Vec LaneRegistration))
  RoleStatus (RoleName HarnessKind (Vec ClaimEntry))
  ClaimEntry (ScopeReference ScopeReason)
  Activity (RoleName ScopeReference ScopeReason TimestampNanos)
  ActivityAcknowledgment (u64)
  ActivityList ((Vec Activity))
  WorkflowRunRequest (WorkflowDigest AuthorizedObjectReference ContractDigest)
  WorkflowRunObservation (WorkflowRunDigest)
  WorkflowRunObservationToken (WorkflowRunDigest)
  WorkflowRunHandle (WorkflowRunDigest)
  WorkflowRunAccepted (WorkflowRunHandle)
  WorkflowReceiptProduced (WorkflowRunHandle WorkflowReceipt)
  WorkflowRunLogReported (WorkflowRunLog)
  WorkflowRunLog (WorkflowRunDigest (Vec StepLog))
  StepLog (WorkflowStepName ModelAttestation StepOutcome)
  ModelAttestation (ProviderName ModelName HostName OperationDigest)
  StepOutcome [(Produced EvaluationDecision) (Failed ScopeReason)]
  WorkflowDefinition ((Vec WorkflowStep) CombinationRule (Option EscalationTarget))
  WorkflowStep (WorkflowStepName ObjectDigest (Option ProviderName) (Vec WorkflowStepName))
  CombinationRule [(Threshold StepThreshold) Unanimous AnyApprove]
  StepThreshold (u64)
  WorkflowRunSnapshot (WorkflowRunHandle (Option WorkflowRunLog) (Option WorkflowReceipt))
  WorkflowRunObservationOpened (WorkflowRunObservationToken WorkflowRunSnapshot)
  WorkflowRunObservationClosed (WorkflowRunObservationToken)
  WorkflowRunUpdate (WorkflowRunDigest (Option WorkflowRunLog) (Option WorkflowReceipt))
  DownstreamComponent [Router Harness Terminal Message Mind System Introspect]
  ApplicationFailureReason [Unreachable Rejected Unimplemented TimedOut Unknown]
  ApplicationSuccess (DownstreamComponent ScopeReason)
  ApplicationFailure (DownstreamComponent ApplicationFailureReason ScopeReason)
  PartialApplied ((Vec ApplicationSuccess) (Vec ApplicationFailure))
  ObservationOpened (ObservationToken)
  ObservationClosed (ObservationToken)

  OperationReceived (OperationKind)
  EffectEmitted (OperationKind EffectOutcome)
  WorkflowRunUpdated (WorkflowRunUpdate)
  ObservationEvent [(OperationReceived OperationReceived) (EffectEmitted EffectEmitted)]
  Observed (ObservationEvent)
  OperationKind [Claim Release Handoff Observe Submit Query RunWorkflow ObserveWorkflowRun WorkflowRunObservationRetraction Watch Unwatch]
  EffectOutcome [Applied Removed Changed Observed StreamOpened StreamClosed NoChange]
}

[
  (Reply
    ClaimAcceptance
    ClaimRejection
    ReleaseAcknowledgment
    HandoffAcceptance
    HandoffRejection
    RoleSnapshot
    LanesObserved
    ActivityAcknowledgment
    ActivityList
    WorkflowRunAccepted
    WorkflowReceiptProduced
    WorkflowRunLogReported
    WorkflowRunObservationOpened
    WorkflowRunObservationClosed
    PartialApplied
    ObservationOpened
    ObservationClosed)

  (Event (belongs WorkflowRunStream)
    WorkflowRunUpdated)

  (Event (belongs ObservationStream)
    Observed)

  (Observable
    (filter default)
    (operation_event OperationReceived)
    (effect_event EffectEmitted))
]
